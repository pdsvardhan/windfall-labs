{
  "name": "momentum_regime",
  "_note": "Momentum on the ~750-name Total Market universe with a regime gate (go to cash when Nifty 500 < its 200DMA), ATR stops, a 2:1 target, sector cap, and full investment of the qualifying names. Built to demonstrate the drawdown fix from the critique (P2 + M1).",
  "universe": { "index": "niftytotalmarket", "point_in_time": false, "filters": ["adtv_cr >= 10"] },
  "entry_filters": ["close > sma50", "close > sma200", "rsi14 > 50", "roc125 > 0"],
  "rank_by": "roc125",
  "rank_order": "desc",
  "n_holdings": 12,
  "weighting": "equal",
  "invest_fully": true,
  "rebalance": "fortnightly",
  "entry_fill": "next_open",
  "sector_cap": 3,
  "max_position_adtv_pct": 0.1,
  "stop_loss": { "type": "atr", "mult": 2.5, "atr_period": 14 },
  "take_profit": { "type": "r_multiple", "r": 2.0 },
  "max_hold_days": 90,
  "regime_filter": { "enabled": true, "benchmark": "NIFTY500", "ma_period": 200, "mode": "binary", "below_exposure": 0.0 },
  "costs_bps": { "brokerage": 3, "stt": 10, "slippage": 15 },
  "capital": 1000000,
  "start": "2018-01-01",
  "end": "2026-06-12",
  "benchmark": "NIFTY500"
}
